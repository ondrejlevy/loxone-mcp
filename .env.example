# Loxone MCP Server - Environment Variables
# Copy this file to .env and update with your values.
#
# REQUIRED: These must be set for the server to start.
# OPTIONAL: These have sensible defaults.

# --- Required: Loxone Miniserver ---
LOXONE_HOST=192.168.1.100
LOXONE_USERNAME=mcp-user
LOXONE_PASSWORD=changeme

# --- Optional: Loxone Connection ---
LOXONE_PORT=80
LOXONE_USE_TLS=false

# --- Optional: Access Control ---
# Modes: read-write (default), read-only, write-only
LOXONE_ACCESS_MODE=read-write

# --- Optional: MCP Server ---
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_TRANSPORT=http
MCP_LOG_LEVEL=INFO
MCP_DEBUG=false

# --- Optional: Metrics ---
METRICS_ENABLED=true

# --- Optional: Audit ---
AUDIT_ENABLED=true
AUDIT_LOG_FILE=logs/audit.jsonl
AUDIT_RETENTION_DAYS=90

# --- Optional: Structure Cache ---
STRUCTURE_CACHE_TTL=3600
STRUCTURE_CHANGE_INTERVAL=300
